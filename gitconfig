[user]
    name = Seamile
    email = lanhuermao@gmail.com
[alias]
    ci = commit
    cls = remote prune origin
    co = checkout
    df = difftool
    lg = log --graph
    lgg = log --stat --graph
    ls = log --pretty=format:'%C(blue)%ad  %C(auto)%h  %s %d' --date=format:'%Y-%m-%d %H:%M'
    st = status
    sw = switch
[color]
    ui = true
[diff]
    tool = vimdiff
    guitool = vscode
[difftool]
    prompt = false
[core]
    editor = vim
	quotepath = false
[init]
	defaultBranch = main
[pull]
	rebase = false
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
